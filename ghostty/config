# Ghostty theme: Snazzy (built-in; see `ghostty +list-themes`. "Snazzy Soft" = softer).
# NOTE: Ghostty lets explicitly-set colors override `theme` no matter the order, so the
# Omarchy dynamic-theme include is commented out below — otherwise its palette would win
# over Snazzy. To follow Omarchy themes again: remove `theme` and re-enable the include.
theme = Snazzy
# config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrainsMono Nerd Font Mono"
font-style = Medium
font-size = 16

# Window
window-padding-x = 16
window-padding-y = 16
confirm-close-surface=false
resize-overlay = never
window-show-tab-bar=always

# Cursor stlying
cursor-style = "block"
cursor-style-blink = true
# no-title: ghostty's integration sets the title to the running command on preexec.
# The title is instead pinned to the CWD by a hook in ~/.zshrc.
shell-integration-features = no-cursor,no-title

# Keyboard bindings
keybind = f11=toggle_fullscreen
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100
keybind = shift+enter=text:\x1b\r

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll

scrollback-limit = 10000
