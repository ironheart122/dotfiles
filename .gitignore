# ─────────────────────────────────────────────────────────────────────────
# Whitelist strategy: ignore everything at the root, re-include only the
# managed trees. Within those, drop runtime noise and (defense-in-depth)
# anything that smells like a secret.
# ─────────────────────────────────────────────────────────────────────────
/*

# Repo meta
!/.gitignore
!/README.md
!/install.sh
!/dot_zshrc

# Managed trees (install.sh symlinks their entries into $HOME)
!/dot_config/
!/dot_claude/
!/dot_codex/

# ── Runtime noise inside managed trees ──
# editor/backup clutter, anywhere
*.bak
*.bak.*
*.save
*~
# hypr: runtime logs + local Claude data
dot_config/hypr/*.log
dot_config/hypr/.claude/
# omarchy: keep themes/branding/hooks; drop stock wallpapers + transient state
dot_config/omarchy/backgrounds/
dot_config/omarchy/current/
dot_config/omarchy/**/*.png
dot_config/omarchy/**/*.jpg
dot_config/omarchy/**/*.jpeg
dot_config/omarchy/**/*.webp

# ── Defense-in-depth: never commit secrets/keys, wherever they appear ──
*.key
*.pem
*.gpg
*.kdbx
*.p12
id_rsa*
id_ed25519*
.env
.env.*
.netrc
*secret*
*token*
*.credentials
.credentials.json
