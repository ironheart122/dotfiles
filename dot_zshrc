# Terminal title (OSC 2): always ends in the CWD, prefixed by the running command.
_title() { print -rn -- $'\e]2;'"$1"$'\a' }
_title_cwd() { _title "${(%):-%~}" }
_title_cmd() { local c=${${1//[[:cntrl:]]}%% *}; _title "${c:t} — ${(%):-%~}" }
autoload -Uz add-zsh-hook
add-zsh-hook precmd _title_cwd
add-zsh-hook preexec _title_cmd
add-zsh-hook chpwd _title_cwd

# Claude Code retitles the window to "Claude Code" on its own; the hook above
# runs before it, so it has to be stopped at the source.
