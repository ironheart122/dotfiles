# ~/.zshrc or ~/.bashrc
WORKTREE_ROOT="$HOME/.local/share/worktrees"

wt() {
  local branch="$1"
  [[ -z "$branch" ]] && { echo "usage: wt <branch> [base]"; return 1; }
  local base="${2:-HEAD}"

  # Derive org/repo from origin URL (handles SSH and HTTPS)
  local url slug
  url=$(git remote get-url origin 2>/dev/null)
  if [[ -n "$url" ]]; then
    # git@github.com:org/repo.git  |  https://github.com/org/repo.git
    slug=$(echo "$url" | sed -E 's#^(git@[^:]+:|https?://[^/]+/)##; s#\.git$##')
  else
    # No remote: fall back to "local/<dirname>"
    slug="local/$(basename "$(git rev-parse --show-toplevel)")"
  fi

  local wt_path="$WORKTREE_ROOT/$slug/$branch"
  mkdir -p "$(dirname "$wt_path")"

  # Reuse existing local branch, DWIM a remote branch into a same-named
  # tracking branch, else create a new branch off base. The remote case
  # matters for PR review: without it, `wt <remote-branch>` silently mints
  # a NEW branch named after the worktree, so the statusline shows the
  # worktree name instead of the branch you meant to check out.
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$wt_path" "$branch"
  elif git show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    git worktree add --track -b "$branch" "$wt_path" "origin/$branch"
  else
    echo "wt: no branch '$branch' locally or on origin — creating it from $base" >&2
    git worktree add "$wt_path" -b "$branch" "$base"
  fi || return 1

  # Copy untracked local config
  local root=$(git rev-parse --show-toplevel)
  for f in .env .env.local .claude/settings.local.json; do
    [[ -f "$root/$f" ]] && { mkdir -p "$wt_path/$(dirname "$f")"; cp "$root/$f" "$wt_path/$f"; }
  done

  cd "$wt_path"
}

wtj() {
  local sel
  sel=$(git worktree list --porcelain | awk '/^worktree /{print $2}' | fzf) && cd "$sel"
}

wtrm() {
  local sel
  sel=$(git worktree list --porcelain | awk '/^worktree /{print $2}' | grep "$WORKTREE_ROOT" | fzf) || return
  git worktree remove "$sel" && git worktree prune
  # Clean up empty org/repo dirs left behind
  rmdir -p "$(dirname "$sel")" 2>/dev/null
}

